{
  "name": "@vibemastery/zurf",
  "description": "A CLI toolkit for AI agents to search the web, browse pages, fetch content, ask questions, and transcribe video — powered by Browserbase, Perplexity, and Supadata.",
  "version": "0.4.0",
  "author": "Luis Güette",
  "bin": {
    "zurf": "./bin/run.js"
  },
  "bugs": "https://github.com/vibemastery/zurf/issues",
  "dependencies": {
    "@browserbasehq/sdk": "^2.9.0",
    "@inquirer/prompts": "^8.3.2",
    "@oclif/core": "^4",
    "@oclif/plugin-autocomplete": "^3.2.42",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-not-found": "^3.2.77",
    "@oclif/plugin-plugins": "^5",
    "@oclif/plugin-warn-if-update-available": "^3.1.57",
    "playwright-core": "^1.58.2",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/mocha": "^10",
    "@types/node": "^18",
    "@types/turndown": "^5.0.6",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^11",
    "oclif": "^4",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/vibemastery/zurf",
  "keywords": [
    "oclif",
    "browserbase",
    "web-search",
    "cli",
    "supadata",
    "transcript"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "zurf",
    "dirname": "zurf",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-autocomplete",
      "@oclif/plugin-help",
      "@oclif/plugin-not-found",
      "@oclif/plugin-plugins",
      "@oclif/plugin-warn-if-update-available"
    ],
    "macos": {
      "identifier": "ai.vibemastery.zurf"
    },
    "topicSeparator": " ",
    "topics": {
      "config": {
        "description": "Inspect zurf configuration"
      },
      "setup": {
        "description": "Configure API keys for Browserbase, Perplexity, and Supadata"
      }
    }
  },
  "repository": "vibemastery/zurf",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "pnpm run lint",
    "prepack": "oclif manifest",
    "pretest": "pnpm run build",
    "test": "mocha --forbid-only \"test/**/*.test.ts\""
  },
  "types": "dist/index.d.ts"
}
